# .env — Madame de la Grande Bouche
# Copy to .env and fill in. End users never see this.

# ── Your trained model files (from Google Drive) ──────────────────────────────
YOLO_MODEL_PATH=/path/to/fyp/runs/fashionpedia_yolo26s/weights/best.pt
ANNOTATION_JSON_PATH=/path/to/fyp/clean/instances_train2020_clean.json
ATTR_MODEL_PATH=/path/to/fyp/attribute_classifier/best_model.pt
ATTR_MAP_PATH=/path/to/fyp/attribute_classifier/attribute_map.json

# ── ChromaDB storage (auto-created if it doesn't exist) ───────────────────────
CHROMA_DB_PATH=./wardrobe_db

# ── API Keys (both free) ──────────────────────────────────────────────────────
# Groq (required): https://console.groq.com → Create API Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenWeatherMap (optional): https://openweathermap.org → API Keys
OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Detection thresholds (optional, defaults shown) ──────────────────────────
CONF_THRESHOLD=0.30
IOU_THRESHOLD=0.45
